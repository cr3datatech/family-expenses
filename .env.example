# Required: OpenAI API key for receipt scanning
OPENAI_API_KEY=sk-your-key-here

# Optional: Default currency (default: EUR)
SNAP_CURRENCY=EUR

# Optional: Payment methods, comma-separated. Use quotes if names contain spaces
# (required for bash when using `source .env` / run.sh).
SNAP_CARDS="Cash,Debit Card,Credit Card"

# Optional: SQLite path (default: ./data/snap.db)
# SNAP_DB_PATH=./data/snap.db
