# Required: OpenAI API key for receipt scanning
OPENAI_API_KEY=sk-your-key-here

# Optional: Default currency (default: EUR)
SNAP_CURRENCY=EUR

# Optional: Custom payment methods, comma-separated (default: Cash, Debit Card, Credit Card)
SNAP_CARDS=Cash,Debit Card,Credit Card

# Optional: Custom database path (default: ./data/snap.db)
# SNAP_DB_PATH=/path/to/your/database.db
