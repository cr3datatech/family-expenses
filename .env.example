# Required: OpenAI API key for receipt scanning (chat completions + vision).
# If you use a "restricted" key, it must allow Model / API requests (scope: model.request).
# Standard (non-restricted) keys work as usual — create one at platform.openai.com → API keys.
OPENAI_API_KEY=sk-your-key-here

# Optional: Default currency (default: EUR)
SNAP_CURRENCY=EUR

# Optional: Payment methods, comma-separated. Use quotes if names contain spaces
# (required for bash when using `source .env` / run.sh).
SNAP_CARDS="Credit Card,Debit Card,ePassi,Cash"

# Optional: SQLite path (default: ./data/snap.db)
# SNAP_DB_PATH=./data/snap.db

# First-time setup: when the users table is empty, create this superuser (then restart the app).
# SNAP_BOOTSTRAP_ADMIN_USER=admin
# SNAP_BOOTSTRAP_ADMIN_PASSWORD=use-a-strong-password

# Session cookie lifetime in seconds (default: 14 days)
# SNAP_SESSION_MAX_AGE_SECONDS=1209600

# Set to 1 behind HTTPS so the session cookie is only sent over TLS
# SNAP_COOKIE_SECURE=1
